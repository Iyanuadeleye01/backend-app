const express = require('express');
const router = express.Router();
const invController = require("../controllers/invController");
const utilities = require("../utilities")
const auth = require("../utilities/auth")

// Route: Vehicles by classification
router.get("/type/:classification_id", invController.buildByClassificationId);

// Route: Single vehicle detail
router.get("/details/:inv_id", invController.buildByInventoryId);

// Route: Intentional 500 error (Task 3)
router.get("/error", invController.triggerError);

// Management view
router.get("/", invController.buildManagement)

// Classificationlist to add inventory
router.get("/add-inventory", invController.buildAddInventory)

// Get inventory for inventory management view
router.get("/getInventory/:classification_id",
     utilities.handleErrors(invController.getInventoryJSON))

// Build edit inventory view
router.get(
  "/edit/:inv_id",
  utilities.handleErrors(invController.editInventoryView)
)

// To handle incoming update request
router.post("/update/", 
  utilities.handleErrors(invController.updateInventory))


  // Employee or admin priviledge access to add classification(get)
router.get("/add-classification",
  auth.checkEmployeeOrAdmin,
  utilities.handleErrors(invController.buildAddClassification)
)

// Employee or admin priviledge access to add classification
router.post("/add-classification",
  auth.checkEmployeeOrAdmin,
  utilities.handleErrors(invController.buildAddClassification)
)

// Privilege access for employee and admin to edit
router.get("/edit/:inv_id",
  auth.checkEmployeeOrAdmin,
  utilities.handleErrors(invController.editInventoryView)
)

// Priviledge access for employee and admin to update the invetory
router.post("/update",
  auth.checkEmployeeOrAdmin,
  utilities.handleErrors(invController.updateInventory)
)

// Show delete page
router.get("/delete/:inv_id",
  auth.checkEmployeeOrAdmin,
  utilities.handleErrors(invController.buildDeleteView)
)

// Process delete
router.post("/delete",
  auth.checkEmployeeOrAdmin,
  utilities.handleErrors(invController.deleteInventory)
)

module.exports = router;