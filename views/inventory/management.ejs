<div class="management-container">
  <!-- Page Title -->
  <header>
    <h1 class="page-title"><%= title %></h1>
  </header>

  <!-- Flash Messages -->
  <% if (messages && messages.length > 0) { %>
    <section class="flash-message">
      <ul>
        <% messages.forEach(msg => { %>
          <li><%= msg %></li>
        <% }) %>
      </ul>
    </section>
  <% } %>

  <!-- Management Actions -->
  <section class="management-actions">
    <nav class="actions-nav">
      <ul>
        <li><a class="btn" href="/inv/add-classification">Add New Classification</a></li>
        <li><a class="btn" href="/inv/add-inventory">Add New Inventory</a></li>
      </ul>
    </nav>

    <h2>Manage Inventory</h2>
    <p>Select a classification from the list to see the items below.</p>

    <!-- Classification Dropdown -->
    <div class="classification-select">
      <%- classificationSelect %>
    </div>

    <!-- Inventory Table -->
    <div class="inventory-table-container">
      <table id="inventoryDisplay"></table>
    </div>

    <!-- Fallback for No JS -->
    <noscript>JavaScript must be enabled to use this page.</noscript>
  </section>
</div>

<!-- Inventory JS -->
<script src="../../js/inventory.js"></script>